{
  "name": "healthchain-core",
  "version": "0.1.0",
  "description": "HealthChain Core — Merkle root registry smart contract for Palma HealthChain",
  "license": "MIT",
  "scripts": {
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "test:gas":       "REPORT_GAS=true hardhat test",
    "coverage":       "hardhat coverage",
    "deploy:local":   "hardhat run scripts/deploy.ts",
    "deploy:fuji":    "hardhat run scripts/deploy.ts --network fuji",
    "demo:local":     "hardhat run scripts/demo.ts",
    "demo:fuji":      "hardhat run scripts/demo.ts --network fuji",
    "verify:fuji":    "hardhat verify --network fuji",
    "clean":          "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify":  "^2.0.0",
    "hardhat":                          "^2.22.0",
    "dotenv":                           "^16.0.0",
    "typescript":                       "^5.0.0",
    "ts-node":                          "^10.9.0",
    "@types/node":                      "^20.0.0",
    "chai":                             "^4.3.0"
  }
}
