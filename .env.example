# ============================================================================
#  HealthChain Core — Environment Variables
#  Copy this file to .env and populate before deploying.
#  NEVER commit .env to version control.
# ============================================================================

# Deployer private key (the wallet that pays gas for deployment)
# Fund with test AVAX at https://faucet.avax.network/ for Fuji testnet
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Owner address (governance multisig — NOT the deployer on production)
# On testnet: can be a single address you control for testing
OWNER_ADDRESS=0x_YOUR_OWNER_ADDRESS_HERE

# Contract address (populated after deployment)
HEALTHCHAIN_CORE_ADDRESS=

# Testnet: optional pre-authorized test issuer
TEST_ISSUER_ADDRESS=
TEST_ISSUER_DID=did:palma:facility:test-institution
TEST_ISSUER_NAME=Palma Test Institution

# Snowtrace/Routescan API key (for contract verification)
# Get at https://routescan.io/ — free tier is sufficient
SNOWTRACE_API_KEY=verifyContract

# Optional: gas reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=
